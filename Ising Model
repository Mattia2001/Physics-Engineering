   "outputs": [],
   "source": [
    "def get_spin_grid(N_rows, N_cols, N_up):\n",
    "    '''\n",
    "    total_spins = N_rows * N_cols\n",
    "\n",
    "    # Check if N_up is not more than the total number of spins\n",
    "    if N_up > total_spins:\n",
    "        raise ValueError(\"N_up cannot be greater than the total number of spins\")\n",
    "\n",
    "    # Create an array with N_up 1's (up spins) and the rest -1's (down spins)\n",
    "    spins = np.array([1]*N_up + [-1]*(total_spins - N_up))\n",
    "    \n",
    "\n",
    "    # Shuffle the array to randomize the spin positions\n",
    "    np.random.shuffle(spins)\n",
    "\n",
    "    # Reshape the array into the grid shape\n",
    "    initial_grid = spins.reshape(N_rows, N_cols)'''\n",
    "    \n",
    "    initial_grid = np.random.choice([-1, 1], size=(N_rows, N_cols))\n",
    "    \n",
    "    return initial_grid"
   ]
  },
