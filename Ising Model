    "It is now time to implement Metropolis Monte-Carlo algorithm for a grid of spins rather than for a one-dimensional array. The procedure is exactly the same, we just have to adapt the previous function to the 2-dimensional case. "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 168,
   "id": "f890269c",
   "metadata": {},
   "outputs": [],
   "source": [
    "def metropolis_monte_carlo(grid, J, temperature, h, max_iter, display_interval):\n",
    "    \n",
    "    try:\n",
    "        # here we start Monte-Carlo simulation\n",
    "\n",
    "        # Let us define the initial configuration, calculate its energy and magnetization\n",
    "        current_grid = grid\n",
    "        current_energy = get_grid_energy(current_grid, J, h)\n",
    "        current_magnetization = get_magnetization(current_grid)\n",
    "\n",
    "        r = np.random.random() # sort a float in range (0,1), which is our accepatance level\n",
    "\n",
    "        T = temperature \n",
    "        k_B = 1\n",
    "        iteration = 0\n",
    "        get_plot = 0\n",
    "        iterations_to_display = [0]\n",
    "\n",
    "        # Create a figure with two subplots\n",
    "        fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 7))\n",
    "        img = ax1.imshow(current_grid, cmap='gray', interpolation='none')\n",
    "        ax1.set_title('Energy= {}'.format(format(current_energy, '.2e')) + '  ' + 'Magnetization ={}'.format(format(current_magnetization, '.2e')) +' ' +  'Iteration= {}'.format(iteration))\n",
    "        \n",
    "        # Initial plot for magnetization\n",
    "        magnetization_data = [current_magnetization]\n",
    "        ax2.plot(magnetization_data, '-')\n",
    "        ax2.set_title('Magnetization per Spin')\n",
    "        ax2.set_xlabel('Iteration')\n",
    "        ax2.set_ylabel('Magnetization')\n",
    "\n",
    "        while iteration < max_iter:\n",
    "\n",
    "            # generate a random position on the grid (i.e. a tuple) where we can flip the spin\n",
    "            flipping_coordinates = np.random.randint(0, len(grid), size=2)\n",
    "            new_grid = np.copy(current_grid)\n",
    "            new_grid[flipping_coordinates[0]][flipping_coordinates[1]] *= -1 # flip the spin at desired location\n",
    "            new_grid_energy = get_grid_energy(new_grid, J, h) # calculate the energy of the new spin grid\n",
    "            new_grid_magnetization = get_magnetization(new_grid) # calculate the new magnetization density\n",
    "\n",
    "            exponential = np.exp(-(1/(k_B*T))*(new_grid_energy - current_energy ))\n",
    "\n",
    "            if r < min(1, exponential):\n",
    "                # accept the new configuration\n",
    "                current_grid = new_grid\n",
    "                current_energy = new_grid_energy\n",
    "                current_magnetization = new_grid_magnetization\n",
    "                #print(f\"Iteration {iteration+1}: {current_grid}, energy: {current_energy} , magnetization: {current_magnetization}\")\n",
    "\n",
    "            else:\n",
    "                 # keep the old configuration\n",
    "                new_grid[flipping_coordinates[0]][flipping_coordinates[1]] *= -1 # flip the spin to re-obtain the old configuration\n",
    "                current_grid = new_grid\n",
    "                current_magnetization = new_grid_magnetization\n",
    "                #print(f\"Iteration {iteration+1}: {current_grid}, energy: {current_energy} , magnetization: {current_magnetization}\")\n",
    "\n",
    "\n",
    "            iteration += 1\n",
    "\n",
    "            # this is the section of plots\n",
    "\n",
    "            get_plot += 1\n",
    "\n",
    "            if get_plot == display_interval:\n",
    "                \n",
    "                iterations_to_display.append(iteration)\n",
    "                \n",
    "                ax1.set_title('Energy= {}'.format(format(current_energy, '.2e')) + '  ' +  'Iteration= {}'.format(iteration)\n",
    "                             + '\\n' + 'Temperature = {}'.format(format(T, '.2e')) + ' ' + 'Coupling = {}'.format(J) \n",
    "                             + ' ' + 'Field = {}'.format(h))\n",
    "                img.set_data(current_grid)\n",
    "                clear_output(wait=True)\n",
    "                \n",
    "                # Update magnetization plot\n",
    "                \n",
    "                magnetization_data.append(current_magnetization)\n",
    "                ax2.clear()\n",
    "                ax2.plot(magnetization_data, '-')\n",
    "                ax2.set_title('Magnetization per Spin')\n",
    "                ax2.set_xlabel('Iteration')\n",
    "                ax2.set_ylabel('Magnetization')\n",
    "                ax2.grid(True)\n",
    "                #ax2.axhline(y = 1, color = 'r', linestyle = '-') \n",
    "                #ax2.axhline(y = -1, color = 'r', linestyle = '-') \n",
    "                #ax2.axhline(y = 0, color = 'r', linestyle = '--') \n",
    "                \n",
    "                display(fig)\n",
    "                plt.pause(0.001)\n",
    "\n",
    "                get_plot = 0\n",
    "\n",
    "        print('You reached the end of the simulation')\n",
    "        toast('Metropolis-Hastings algorithm terminated')\n",
    "        \n",
    "        #return current_grid, current_energy, current_magnetization \n",
    "    except KeyboardInterrupt:\n",
    "        print(\"Metropolis-Hastings algorithm stopped by the user\")"
   ]
